{
    "description": "Home row mods - ctrl, opt, shift, command",
    "manipulators": [
        {
            "from": { "key_code": "a" },
            "to_delayed_action": {
                "to_if_canceled": [{ "key_code": "a" }],
                "to_if_invoked": [{ "key_code": "vk_none" }]
            },
            "to_if_alone": [
                {
                    "halt": true,
                    "key_code": "a"
                }
            ],
            "to_if_held_down": [
                {
                    "halt": true,
                    "key_code": "left_option"
                }
            ],
            "type": "basic"
        },
        {
